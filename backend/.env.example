# ==================== 环境变量配置模板 ====================
# 使用方法：复制此文件为 .env 并填入真实值
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env

# ==================== 必需配置 ====================

# DeepSeek API Configuration
# 获取 API Key: https://platform.deepseek.com/
# ⚠️ 重要：不要将此文件提交到版本控制系统
DEEPSEEK_API_KEY=sk-your-api-key-here

# Server Configuration
HOST=0.0.0.0
PORT=8080
RELOAD=true

# CORS Configuration
# 允许访问的前端域名，多个域名用逗号分隔
# 开发环境：http://localhost:5173
# 生产环境：https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# ==================== 数据库配置 ====================

# 数据库类型：sqlite 或 mysql
DATABASE_TYPE=mysql

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password-here
MYSQL_DATABASE=task_planner

# 数据库连接池配置
DB_POOL_MAX=20          # 最大连接数
DB_POOL_MIN=5           # 最小空闲连接数
DB_POOL_MAX_CACHED=10   # 连接池最大缓存连接数

# 如果使用 SQLite（仅用于开发测试），请改为：
# DATABASE_TYPE=sqlite

# ==================== Redis 缓存配置 ====================

# Redis 缓存（可选，用于缓存任务列表、LLM 响应等）
# 本地 Redis: redis://localhost:6379/0
# 远程 Redis: redis://:password@hostname:6379/0
REDIS_URL=redis://localhost:6379/0

# 缓存过期时间（秒）
CACHE_TTL_TASKS=300         # 任务列表缓存 5 分钟
CACHE_TTL_LLM_RESPONSE=600  # LLM 响应缓存 10 分钟

# ==================== 可选配置（未来扩展）====================

# Logging Level
# LOG_LEVEL=INFO

# JWT Secret (多用户认证时使用)
# JWT_SECRET=change-this-to-random-string-in-production
