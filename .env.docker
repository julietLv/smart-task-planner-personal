# ============================================================
# Docker 环境变量配置模板
# 使用方法：复制此文件为 .env 并填入你的真实 API Key
#   cp .env.docker .env
# ============================================================

# ---------- DeepSeek API（⚠️ 必填）----------
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# ---------- 天气 API（⚠️ 必填）----------
# 获取地址：https://www.qweather.com/
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_HOST=n6564vxqt9.re.qweatherapi.com
DEFAULT_CITY=北京

# ---------- 数据库（完整版使用）----------
MYSQL_ROOT_PASSWORD=demo_plan_2024
MYSQL_DATABASE=task_planner

# ---------- 端口映射（按需修改）----------
# 前端访问端口
FRONTEND_PORT=80
# 后端 API 端口（调试用）
BACKEND_PORT=8080
# MySQL 端口（完整版）
MYSQL_PORT=3307
# Redis 端口（完整版）
REDIS_PORT=6380

# ---------- CORS ----------
ALLOWED_ORIGINS=*
